{
  "name": "qiymet-az",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "npx wrangler dev",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler deploy",
    "db:migrate": "npx wrangler d1 migrations apply qiymet_db --local",
    "db:migrate:prod": "npx wrangler d1 migrations apply qiymet_db --remote"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "hono": "^4.12.9",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
